{
  "name": "aseje",
  "displayName": "ASEJE",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Other",
    "Debuggers"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onDebug:python_D",
    "onLanguage:python",
    "onCommand:audio.playSound",
    "onView:aseje.sidebarView"
  ],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "settings",
      "properties": {
        "aseje.fontSize": {
          "type": "number",
          "default": 14,
          "description": "The font size used in both setting and terminal"
      },
        "aseje.audio.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable ASEJE audio notifications during debugging."
        },
        "aseje.audio.volume": {
          "type": "number",
          "default": 0.45,
          "minimum": 0,
          "maximum": 1,
          "description": "Volume for ASEJE debug sounds from 0.0 to 1.0."
        },
        "aseje.audio.source": {
          "type": "string",
          "default": "media/beep.wav",
          "description": "Relative path inside the extension to the sound file ASEJE should play."
        },
        "aseje.audio.events": {
          "type": "array",
          "default": ["start", "breakpoint", "exception", "terminate"],
          "items": {
            "type": "string",
            "enum": ["start", "breakpoint", "exception", "step", "pause", "terminate"]
          },
          "description": "Debug events that should trigger ASEJE audio notifications."
        }
      }
    },
      
      {  "command": "aseje.helloWorld", "title": "Hello World" },
      { "command": "aseje.textSetting", "title": "text Setting" },
      { "command": "aseje.stepOne", "title": "step one" },
      { "command": "aseje.textChange", "title": "textChange" },
      {"command": "audio.playSound", "title": "Play Sound"},
      {
        "command": "aseje.toggleBeginnerMode",
        "title": "$(pencil) Toggle Beginner Mode (ASEJE)",
        "category": "ASEJE"
      },
      {
        "command": "aseje.showWalkthrough",
        "title": "$(book) Start ASEJE Guided Walkthrough",
        "category": "ASEJE"
      },
      {
        "command": "aseje.createStarterProject",
        "title": "$(new-file) Create Starter Project",
        "category": "ASEJE"
      },
      { "command": "aseje.addBreakpointNote", "title": "$(note) Add Breakpoint Note (ASEJE)" },
      { "command": "aseje.insertAutoComment", "title": "$(comment) Insert Auto Comment (ASEJE)" },
      { "command": "aseje.incrementBreakpointHit", "title": "Increment Breakpoint Hit (Debug Test)" },
      { "command": "aseje.reference", "title": "Open python escape sequence reference" }
    ],

    "menus": {
      "editor/title": [
        {
          "command": "aseje.toggleBeginnerMode",
          "group": "navigation",
          "when": "editorFocus"
        }
      ],
      "commandPalette": [
        { "command": "aseje.toggleBeginnerMode" },
        { "command": "aseje.showWalkthrough" },
        { "command": "aseje.createStarterProject" },
        { "command": "aseje.addBreakpointNote" },
        { "command": "aseje.insertAutoComment" }
      ],
      "editor/context": [
        { "command": "aseje.addBreakpointNote", "group": "aseje_debug@1" },
        { "command": "aseje.insertAutoComment", "group": "aseje_debug@2" }
      ]
    },

    "debuggers": [
      {
        "type": "python_D",
        "label": "ASEJE Python",
        "runtime": "node",
        "program": "./pyDebuggerStart.py",
        "languages": ["python"],
        "configurationAttributes": {
          "launch": {
            "required": ["program"],
            "properties": {
              "program": {
                "type": "string",
                "description": "Debug start"
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "python_D",
            "request": "launch",
            "name": "ASEJE Python",
            "program": "${workspaceFolder}/app.py"
          }
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "asejeSidebar",
          "title": "ASEJE",
          "icon": "$(lightbulb)"
        }
      ]
    },
    "views": {
      "asejeSidebar": [
        {
          "id": "aseje.sidebarView",
          "name": "ASEJE Sidebar",
          "type": "webview"
        }
      ]
    },

    "walkthroughs": [
      {
        "id": "aseje.myFirstWalkthrough",
        "title": "Start Coding with ASEJE",
        "description": "Your guided tour to a simpler VS Code experience.",
        "steps": [
          {
            "id": "aseje.walkthrough.step1.intro",
            "title": "Welcome to Simplified Coding",
            "description": "This is the first step. Explain why VS Code is overwhelming and how ASEJE simplifies the UI. You can link to a Markdown file here.",
            "completionEvents": ["onCommand:aseje.toggleBeginnerMode"]
          },
          {
            "id": "aseje.walkthrough.step2.project",
            "title": "Create Your First Project",
            "description": "Click the 'Create Starter Project' command below to begin a sample file.",
            "command": "aseje.createStarterProject",
            "completionEvents": ["onCommand:aseje.createStarterProject"]
          }
        ]
      }
    ]
  },

  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.104.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.34.0"
  },
  "dependencies": {
    "@vscode/debugadapter": "^1.68.0"
  }
}
